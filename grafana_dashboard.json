{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus" },
    { "type": "panel", "id": "timeseries", "name": "Time series" },
    { "type": "panel", "id": "stat", "name": "Stat" },
    { "type": "panel", "id": "gauge", "name": "Gauge" }
  ],
  "id": null,
  "uid": "sdn-ddos-nhom4",
  "title": "SDN DDoS Detection - Nhom 4",
  "description": "Dashboard giam sat DDoS dua tren Shannon Entropy - Ryu SDN Controller",
  "tags": ["sdn", "ddos", "entropy", "nhom4"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": true,
  "refresh": "3s",
  "time": { "from": "now-5m", "to": "now" },
  "timepicker": {},
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 100,
      "title": "TONG QUAN HE THONG",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Trang Thai",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "BINH THUONG", "color": "green" } }, "type": "value" },
            { "options": { "1": { "text": "BOTNET!", "color": "red" } }, "type": "value" },
            { "options": { "2": { "text": "SPOOFED!", "color": "orange" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 },
              { "color": "orange", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sdn_system_status", "refId": "A", "legendFormat": "Status" }
      ]
    },
    {
      "id": 2,
      "title": "Tan Cong Botnet",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sdn_attack_botnet_total", "refId": "A", "legendFormat": "Botnet" }
      ]
    },
    {
      "id": 3,
      "title": "Tan Cong Spoofed IP",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sdn_attack_spoof_total", "refId": "A", "legendFormat": "Spoofed" }
      ]
    },
    {
      "id": 4,
      "title": "IP Dang Bi Block",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sdn_blocked_ips_current", "refId": "A", "legendFormat": "Blocked" }
      ]
    },
    {
      "id": 5,
      "title": "Packet-In PPS",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "pps"
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sdn_packet_in_pps", "refId": "A", "legendFormat": "PPS" }
      ]
    },
    {
      "id": 6,
      "title": "Tong Packet-In",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sdn_packet_in_total", "refId": "A", "legendFormat": "Total" }
      ]
    },

    {
      "id": 200,
      "title": "ENTROPY MONITORING",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 10,
      "title": "Shannon Entropy theo thoi gian",
      "description": "Do thi entropy voi 2 nguong: LOW (Botnet) va HIGH (Spoofed IP)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "pointSize": 4,
            "showPoints": "auto",
            "spanNulls": false,
            "axisSoftMin": 0,
            "axisSoftMax": 10
          },
          "unit": "short",
          "decimals": 2
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Nguong Cao (Spoofed)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Nguong Thap (Botnet)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Entropy" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#37872D" } },
              { "id": "custom.lineWidth", "value": 3 }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "min", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "expr": "sdn_entropy_value", "refId": "A", "legendFormat": "Entropy" },
        { "expr": "sdn_entropy_threshold_high", "refId": "B", "legendFormat": "Nguong Cao (Spoofed)" },
        { "expr": "sdn_entropy_threshold_low", "refId": "C", "legendFormat": "Nguong Thap (Botnet)" }
      ]
    },
    {
      "id": 11,
      "title": "Entropy Gauge",
      "type": "gauge",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 10,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1.5 },
              { "color": "orange", "value": 5.5 }
            ]
          },
          "decimals": 2
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sdn_entropy_value", "refId": "A", "legendFormat": "Entropy" }
      ]
    },
    {
      "id": 12,
      "title": "So IP duy nhat",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sdn_entropy_unique_ips", "refId": "A", "legendFormat": "Unique IPs" }
      ]
    },
    {
      "id": 13,
      "title": "Goi tin trong Window",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sdn_entropy_window_packets", "refId": "A", "legendFormat": "Window Size" }
      ]
    },

    {
      "id": 300,
      "title": "LUU LUONG MANG",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "collapsed": false
    },
    {
      "id": 20,
      "title": "Packet-In PPS theo thoi gian",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme"
          },
          "unit": "pps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        { "expr": "sdn_packet_in_pps", "refId": "A", "legendFormat": "Packet-In PPS" }
      ]
    },
    {
      "id": 21,
      "title": "Port RX Packets/s (theo Switch:Port)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          },
          "unit": "pps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "expr": "sdn_port_rx_pps", "refId": "A", "legendFormat": "SW{{dpid}}:Port{{port}} RX" }
      ]
    },

    {
      "id": 400,
      "title": "PORT STATISTICS",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "collapsed": false
    },
    {
      "id": 30,
      "title": "Port TX Packets/s",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 },
          "unit": "pps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "expr": "sdn_port_tx_pps", "refId": "A", "legendFormat": "SW{{dpid}}:Port{{port}} TX" }
      ]
    },
    {
      "id": 31,
      "title": "Port Errors (RX + TX)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "expr": "sdn_port_rx_errors_total", "refId": "A", "legendFormat": "SW{{dpid}}:P{{port}} RX Err" },
        { "expr": "sdn_port_tx_errors_total", "refId": "B", "legendFormat": "SW{{dpid}}:P{{port}} TX Err" }
      ]
    },
    {
      "id": 32,
      "title": "Port Dropped (RX + TX)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "expr": "sdn_port_rx_dropped_total", "refId": "A", "legendFormat": "SW{{dpid}}:P{{port}} RX Drop" },
        { "expr": "sdn_port_tx_dropped_total", "refId": "B", "legendFormat": "SW{{dpid}}:P{{port}} TX Drop" }
      ]
    },
    {
      "id": 33,
      "title": "Port RX Bytes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 15, "gradientMode": "scheme" },
          "unit": "decbytes"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "expr": "sdn_port_rx_bytes_total", "refId": "A", "legendFormat": "SW{{dpid}}:P{{port}} RX" }
      ]
    },
    {
      "id": 34,
      "title": "Port TX Bytes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 15, "gradientMode": "scheme" },
          "unit": "decbytes"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "expr": "sdn_port_tx_bytes_total", "refId": "A", "legendFormat": "SW{{dpid}}:P{{port}} TX" }
      ]
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
